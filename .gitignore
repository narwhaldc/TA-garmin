# secrets / session tokens — NEVER commit
# NOTE: bare names below match at ANY depth (repo ROOT *and* tools/); the **/ forms
# are explicit belt-and-suspenders so root-level creds can never leak.
.garminconnect/
*garmin_tokens*.json
oauth1_token.json
oauth2_token.json
.env
/.env
**/.env
# personal sample dumps (health data + device ids)
garmin_samples/
tools/garmin_samples/
# build artifacts
*.spl
__pycache__/
*.pyc
.DS_Store
# runtime state (never commit)
garmin_checkpoint.json
garmin_dedup_store.json
garmin_sync.lock
*.lock
*.tmp

# HEC targets (tokens) — never commit (root and any subdir)
garmin_targets.json
**/garmin_targets.json
